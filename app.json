{
  "expo": {
    "name": "FloraScan",
    "slug": "florascan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "florascan",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.zafran.florascan",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/notification-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FloraScan to access your camera to scan and identify plant diseases."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FloraScan to access your photos to upload plant images for diagnosis."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#4A7C59",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9718e379-a9d8-472c-82ae-8e89d1f79ed1"
      }
    }
  }
}
